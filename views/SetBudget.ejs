<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Set Budget</title>
    <style>
        body {
            background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
            min-height: 100vh;
        }

        .budget-shell {
            max-width: 760px;
        }

        .budget-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(15, 23, 42, 0.08);
        }
    </style>
</head>
<body>
    <%- include('partial/navbar') %>

    <%
        const currentBudget = Number(typeof totalBudget !== 'undefined' ? totalBudget : 0) || 0;
        const currentStartDate = typeof budgetStartDate !== 'undefined' ? budgetStartDate : '';
        const currentEndDate = typeof budgetEndDate !== 'undefined' ? budgetEndDate : '';
    %>

    <main class="container py-5 budget-shell">
        <div class="card budget-card">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <h1 class="h3 mb-2">Set Budget</h1>
                    <p class="text-muted mb-0">Enter your budget amount and the date range it should apply to.</p>
                </div>

                <div class="alert alert-light border mb-4" role="status">
                    Current budget: <strong>$<%= currentBudget.toFixed(2) %></strong>
                </div>

                <form action="<%= setBudgetUrl || '/set' %>" method="POST" class="row g-3">
                    <div class="col-12">
                        <label for="amountOfBudget" class="form-label">Amount of budget</label>
                        <input
                            type="number"
                            class="form-control form-control-lg"
                            id="amountOfBudget"
                            name="amountOfBudget"
                            min="0"
                            step="0.01"
                            placeholder="0.00"
                            value="<%= currentBudget ? currentBudget : '' %>"
                            required
                        >
                    </div>

                    <div class="col-12 col-md-6">
                        <label for="startDate" class="form-label">Start date</label>
                        <input
                            type="date"
                            class="form-control form-control-lg"
                            id="startDate"
                            name="startDate"
                            value="<%= currentStartDate %>"
                            required
                        >
                    </div>

                    <div class="col-12 col-md-6">
                        <label for="endDate" class="form-label">End date</label>
                        <input
                            type="date"
                            class="form-control form-control-lg"
                            id="endDate"
                            name="endDate"
                            value="<%= currentEndDate %>"
                            required
                        >
                    </div>

                    <div class="col-12 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg w-100">Save Budget</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>