<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Delete Portion</title>
    <style>
        body {
            background: linear-gradient(180deg, #f6f8fb 0%, #eef2f7 100%);
            min-height: 100vh;
        }

        .delete-shell {
            max-width: 960px;
        }

        .delete-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(15, 23, 42, 0.08);
        }

        .table thead th {
            background: #f8fafc;
            color: #475569;
            border-bottom-color: #e5e7eb;
        }

        .table tbody td {
            vertical-align: middle;
        }
    </style>
</head>
<body>
    <main class="container py-5 delete-shell">
        <div class="card delete-card">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3 mb-4">
                    <div>
                        <h1 class="h3 mb-2">Delete Portion</h1>
                        <p class="text-muted mb-0">Review all allocated portions and remove any entry you no longer need.</p>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Portion Name</th>
                                <th scope="col" class="text-end">Amount Allocated</th>
                                <th scope="col" class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% const rows = Array.isArray(spendingBreakdown) ? spendingBreakdown : []; %>
                            <% rows.forEach((portion) => { %>
                                <tr>
                                    <td><%= portion.reason %></td>
                                    <td class="text-end"><%= Number(portion.amount) || 0 %></td>
                                    <td class="text-end">
                                        <form action="/DeletePortion/<%= portion.id %>" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-danger btn-sm">delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <div class="badge text-bg-light border fs-6 px-3 py-2">Total allocated: <%= Number(totalAllocated) || 0 %></div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
