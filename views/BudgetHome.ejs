<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Budget Home</title>
    <style>
        body {
            background: linear-gradient(180deg, #f6f8fb 0%, #eef2f7 100%);
            min-height: 100vh;
        }

        .dashboard-shell {
            max-width: 1100px;
        }

        .budget-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(15, 23, 42, 0.08);
        }

        .progress-frame {
            width: 100%;
            height: 2.25rem;
            background: #e9edf3;
            border-radius: 999px;
            overflow: hidden;
            border: 1px solid #d7dde6;
        }

        .progress-segment {
            height: 100%;
            float: left;
        }

        .tracker-value {
            font-size: 1.15rem;
            font-weight: 700;
            color: #1f2937;
        }

        .tracker-label {
            color: #6b7280;
            font-size: 0.95rem;
        }

        .reason-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            font-weight: 600;
        }

        .reason-dot {
            width: 0.9rem;
            height: 0.9rem;
            border-radius: 999px;
            flex: 0 0 auto;
        }

        .table thead th {
            background: #f8fafc;
            color: #475569;
            border-bottom-color: #e5e7eb;
        }

        .table tbody td {
            vertical-align: middle;
        }
    </style>
</head>
<body>
    <%- include('partial/navbar') %>

    <%
        const totalBudgetValue = Number(typeof budgetTotal !== 'undefined' ? budgetTotal : 0) || 0;
        const sourceRows = Array.isArray(spendingBreakdown) ? spendingBreakdown : [];
        const fallbackRows = [
            { reason: 'Housing', color: '#2563eb' },
            { reason: 'Food', color: '#16a34a' },
            { reason: 'Transport', color: '#f97316' }
        ];
        const moneyFormatter = new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD'
        });

        const rows = Array.from({ length: 3 }, (_, index) => {
            const item = sourceRows[index] || {};
            return {
                reason: item.reason || fallbackRows[index].reason,
                amount: Number(item.amount) || 0,
                color: item.color || fallbackRows[index].color
            };
        });

        const totalSpentValue = rows.reduce((sum, row) => sum + row.amount, 0);
        const barWidth = totalBudgetValue > 0 ? Math.min(100, (totalSpentValue / totalBudgetValue) * 100) : 0;
        const segmentWidths = rows.map((row) => totalBudgetValue > 0 ? Math.max(0, (row.amount / totalBudgetValue) * 100) : 0);
    %>

    <main class="container py-5 dashboard-shell">
        <div class="card budget-card">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3 mb-4">
                    <div>
                        <h1 class="h3 mb-2">Budget Overview</h1>
                        <p class="text-muted mb-0">Track how each spending reason contributes to your overall budget.</p>
                    </div>
                    <div class="text-md-end">
                        <div class="tracker-label">Total spent</div>
                        <div class="tracker-value"><%= moneyFormatter.format(totalSpentValue) %> of <%= moneyFormatter.format(totalBudgetValue) %></div>
                    </div>
                </div>

                <div class="progress-frame mb-3" aria-label="Budget allocation progress">
                    <% if (barWidth > 0) { %>
                        <% rows.forEach((row, index) => { %>
                            <% if (segmentWidths[index] > 0) { %>
                                <div
                                    class="progress-segment"
                                    style="width: <%= segmentWidths[index] %>%; background-color: <%= row.color %>"
                                    title="<%= row.reason %>: <%= moneyFormatter.format(row.amount) %>"
                                ></div>
                            <% } %>
                        <% }) %>
                    <% } %>
                </div>

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                    <div class="tracker-label">When the budget is at $0 spent, the bar stays empty.</div>
                    <div class="badge text-bg-light border">Spent <%= moneyFormatter.format(totalSpentValue) %> / Budget <%= moneyFormatter.format(totalBudgetValue) %></div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Reason for Spending</th>
                                <th scope="col" class="text-end">Amount Spent</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% rows.forEach((row) => { %>
                                <tr>
                                    <td>
                                        <span class="reason-chip">
                                            <span class="reason-dot" style="background-color: <%= row.color %>"></span>
                                            <span style="color: <%= row.color %>"><%= row.reason %></span>
                                        </span>
                                    </td>
                                    <td class="text-end"><%= moneyFormatter.format(row.amount) %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 d-flex flex-wrap gap-2">
                    <a href="<%= allocatePortionUrl || '/AllocatePortion' %>" class="btn btn-primary">Add Portion</a>
                    <a href="/EditPortion" class="btn btn-outline-secondary">Edit Portion</a>
                </div>
            </div>
        </div>
    </main>
</body>
</html>