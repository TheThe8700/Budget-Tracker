<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Edit Budget</title>
</head>
<body>
    <%- include('partial/navbar') %>

    <%
        const currentBudget = Number(typeof totalBudget !== 'undefined' ? totalBudget : 0) || 0;
        const editUrl = editBudgetUrl || '/EditBudget';
    %>

    <main class="container py-5" style="max-width: 760px;">
        <div class="card border-0 shadow-lg rounded-4">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <h1 class="h3 mb-2">Edit Budget</h1>
                    <p class="text-muted mb-0">Adjust your budget by adding to or subtracting from the current total.</p>
                </div>

                <div class="alert alert-light border mb-4" role="status">
                    Current total budget: <strong>$<%= currentBudget.toFixed(2) %></strong>
                </div>

                <form action="<%= editUrl %>" method="POST" class="row g-3">
                    <div class="col-12">
                        <label for="amount" class="form-label">Amount</label>
                        <input
                            type="number"
                            class="form-control form-control-lg"
                            id="amount"
                            name="amount"
                            min="0"
                            step="0.01"
                            placeholder="0.00"
                            required
                        >
                    </div>

                    <div class="col-12">
                        <label for="operation" class="form-label">Action</label>
                        <select id="operation" name="operation" class="form-select form-select-lg" required>
                            <option value="add" selected>Add to budget</option>
                            <option value="subtract">Subtract from budget</option>
                        </select>
                    </div>

                    <div class="col-12 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg w-100">Update Total Budget</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>