<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Allocate Portion</title>
    <style>
        body {
            background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
            min-height: 100vh;
        }

        .portion-shell {
            max-width: 720px;
        }

        .portion-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(15, 23, 42, 0.08);
        }
    </style>
</head>
<body>
    <%- include('partial/navbar') %>

    <main class="container py-5 portion-shell">
        <div class="card portion-card">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <h1 class="h3 mb-2">Allocate Portion</h1>
                    <p class="text-muted mb-0">Fill in the details below to add a new portion to your budget breakdown.</p>
                </div>

                <form action="/AllocatePortion" method="POST" class="row g-3">
                    <div class="col-12">
                        <label for="reason" class="form-label">Name</label>
                        <input type="text" class="form-control form-control-lg" id="reason" name="reason" placeholder="Enter portion name" required>
                    </div>

                    <div class="col-12">
                        <label for="amountSpent" class="form-label">Amount</label>
                        <input type="number" class="form-control form-control-lg" id="amountSpent" name="amountSpent" placeholder="0.00" min="0" step="0.01" required>
                    </div>

                    <div class="col-12">
                        <label for="assignedColor" class="form-label">Color</label>
                        <input type="color" class="form-control form-control-color form-control-lg" id="assignedColor" name="assignedColor" value="#2563eb" title="Choose a color" required>
                    </div>

                    <div class="col-12">
                        <label for="date" class="form-label">Date</label>
                        <input type="date" class="form-control form-control-lg" id="date" name="date" required>
                    </div>

                    <div class="col-12 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg w-100">Add Portion</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>